---
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';
---

<Layout title="Rachid Ruffin | Développeur Fullstack">
  <article class="relative z-10 max-w-4xl mx-auto px-6 pt-32 pb-20">
    <!-- ═══════════════════════════════════════════════
         HERO — Intro pure, plein écran
    ════════════════════════════════════════════════ -->
    <section
      id="hero"
      class="min-h-[70vh] flex flex-col justify-center text-center mb-20 reveal-on-scroll"
      aria-labelledby="hero-title"
    >
      <div id="hero-title" class="sr-only">Développeur Fullstack — Rachid Ruffin</div>

      <div
        class="inline-block mb-6 px-4 py-1 rounded-full glass-card text-sm text-cyan-400 tracking-wide mx-auto"
      >
        ✦ Ouvert aux opportunités
      </div>

      <h1 class="text-6xl font-bold mb-6 leading-tight">Rachid Ruffin</h1>

      <p class="text-2xl font-light text-violet-300 mb-4">
        <span id="typewriter"></span><span class="typewriter-cursor">|</span>
      </p>

      <p class="text-lg text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed">
        Je conçois des applications web modernes — du front au back. Ma prédilection va au <strong
          class="text-slate-200">JavaScript</strong
        >, mais je parle aussi couramment <strong class="text-slate-200">Python</strong>
        et <strong class="text-slate-200">PHP</strong>.
      </p>

      <div class="flex gap-4 justify-center flex-wrap">
        <a href="#projets" class="btn-primary px-8 py-3 rounded-xl font-semibold text-white">
          Voir mes projets →
        </a>
        <a href="#contact" class="btn-outlined px-8 py-3 rounded-xl font-semibold text-slate-300">
          Me contacter
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="scroll-indicator mt-16 mx-auto" aria-hidden="true">
        <span></span>
      </div>
    </section>

    <!-- À PROPOS -->
    <section id="about" class="mb-28 reveal-on-scroll" aria-labelledby="about-heading">
      <SectionDivider />

      <h2 id="about-heading" class="text-3xl font-bold mb-8">
        Qui suis-<span class="neon-text">je</span> ?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="glass-card p-6 md:col-span-2">
          <p class="text-slate-300 leading-relaxed mb-4">
            Développeur Fullstack passionné par la création d'expériences web modernes et
            performantes. J'aime concevoir des interfaces soignées autant que des architectures
            backend solides.
          </p>
          <p class="text-slate-400 leading-relaxed">
            <!-- ⚙️ À personnaliser avec ta vraie bio -->
            Toujours en apprentissage, je construis mes projets avec rigueur et curiosité. Mon objectif
            : livrer du code propre, accessible et maintenable.
          </p>
        </div>

        <!-- Stats -->
        <div class="flex flex-col gap-4">
          <div class="glass-card p-5 text-center">
            <div class="text-3xl font-bold neon-text mb-1">2+</div>
            <div class="text-xs text-slate-500 uppercase tracking-widest">Ans d'XP</div>
          </div>
          <div class="glass-card p-5 text-center">
            <div class="text-3xl font-bold neon-text mb-1">5+</div>
            <!-- ⚙️ À ajuster avec ton vrai nombre -->
            <div class="text-xs text-slate-500 uppercase tracking-widest">Projets</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         COMPÉTENCES
    ════════════════════════════════════════════════ -->
    <section class="mb-28 reveal-on-scroll" aria-labelledby="skills-heading">
      <SectionDivider number="02" label="Compétences" />

      <h2 id="skills-heading" class="text-3xl font-bold mb-8">
        Mes <span class="neon-text">Compétences</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Frontend -->
        <div class="glass-card p-6">
          <h3 class="text-lg font-semibold mb-5 text-cyan-400">Frontend</h3>
