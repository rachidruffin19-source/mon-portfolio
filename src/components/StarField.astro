<canvas id="starfield" aria-hidden="true"></canvas>

<script>
  /**
   * 📚 LEÇON — Pourquoi on fait ça ?
   *
   * AVANT : <script is:inline> → le code JS était copié-collé directement dans le HTML
   *   - Pas de vérification TypeScript
   *   - Code dupliqué (existait aussi dans starfield.ts)
   *   - Pas optimisé par Vite (pas de tree-shaking, pas de minification)
   *
   * MAINTENANT : <script> (sans is:inline) → Astro bundle ce script avec Vite
   *   - Vite compile le TypeScript automatiquement
   *   - Vite minifie le code pour la prod
   *   - Une seule source de vérité : starfield.ts
   *   - Si tu corriges un bug dans starfield.ts → le composant est automatiquement mis à jour
   *
   * C'est le principe DRY : Don't Repeat Yourself.
   */
  import { initStarfield } from '../scripts/starfield';

  // DOMContentLoaded guard : s'assurer que le canvas existe avant d'initialiser
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStarfield);
  } else {
    initStarfield();
  }
</script>

<style>
  canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none; /* 📚 Le canvas ne bloque pas les clics sur les éléments derrière */
  }
</style>
