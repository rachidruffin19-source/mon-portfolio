<canvas id="starfield"></canvas>

<script>
  const canvas = document.getElementById('starfield');
  const ctx = canvas.getContext('2d');
  let stars = [];
  let scrollY = 0;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function createStars() {
    const palette = ['255,255,255', '200,170,255', '170,220,255', '220,200,255'];
    stars = Array.from({ length: 820 }, () => ({
      x:             Math.random() * window.innerWidth,
      y:             Math.random() * 6000,          // étalées sur toute la page
      size:          Math.random() * 1.8 + 0.2,
      baseOpacity:   Math.random() * 0.6 + 0.15,
      twinkleSpeed:  Math.random() * 0.025 + 0.004,
      twinkleOffset: Math.random() * Math.PI * 2,
      parallax:      Math.random() * 0.45 + 0.05,   // vitesse de parallaxe
      color:         palette[Math.floor(Math.random() * palette.length)],
    }));
  }

  function draw(time) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const s of stars) {
      const twinkle   = Math.sin(time * s.twinkleSpeed + s.twinkleOffset);
      const opacity   = s.baseOpacity * (0.45 + 0.55 * ((twinkle + 1) / 2));
      const screenY   = s.y - scrollY * s.parallax;

      // on n'affiche que les étoiles visibles
      if (screenY < -4 || screenY > canvas.height + 4) continue;

      ctx.beginPath();
      ctx.arc(s.x, screenY, s.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${s.color}, ${opacity.toFixed(3)})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  resize();
  createStars();

  window.addEventListener('resize', () => { resize(); createStars(); });
  window.addEventListener('scroll', () => { scrollY = window.scrollY; });

  requestAnimationFrame(draw);
</script>

<style>
  #starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>