---
import type { NavLink } from '../types';

interface Props {
  links?: NavLink[];
}
const { links } = Astro.props as Props;

const defaultLinks: NavLink[] = [
  { label: 'À propos', href: '#about' },
  { label: 'Projets', href: '#projets' },
  { label: 'Contact', href: '#contact' },
];
const navLinks = links && links.length ? links : defaultLinks;
---

<nav class="navbar" id="navbar" aria-label="Navigation principale">
  <!-- Logo -->
  <a href="/" class="nav-logo" aria-label="Accueil — RachidRuffin.dev">
    <span class="logo-first">RachidRuffin</span><span class="logo-tld">.dev</span>
  </a>

  <!-- Hamburger mobile -->
  <button class="hamburger" id="hamburger-menu" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <!-- Nav links -->
  <div class="nav-links" id="nav-menu">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          aria-label={link.ariaLabel || link.label}
        >
          {link.label}
        </a>
      ))
    }

    <!-- GitHub visible sur desktop uniquement -->
    <a
      href="https://github.com/rachidruffin19-source"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="nav-github-btn"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
        ></path>
      </svg>
      GitHub
    </a>
  </div>
</nav>

<style>
  .hamburger {
    display: none;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    gap: 6px;
  }
  .hamburger span {
    width: 24px;
    height: 3px;
    background: linear-gradient(135deg, #a78bfa, #22d3ee);
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }
    .hamburger.active span:nth-child(1) {
      transform: rotate(45deg) translate(10px, 10px);
    }
    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }
    .hamburger.active span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -7px);
    }
    /* Cacher le bouton GitHub sur mobile (déjà dans SocialSidebar) */
    .nav-github-btn {
      display: none !important;
    }
  }
</style>

<script type="module" is:inline>
  // ── Hamburger toggle ──────────────────────────────────
  const hamburger = document.getElementById('hamburger-menu');
  const navMenu = document.getElementById('nav-menu');
  if (hamburger && navMenu) {
    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navMenu.classList.toggle('active');
      hamburger.setAttribute(
        'aria-expanded',
        hamburger.getAttribute('aria-expanded') === 'false' ? 'true' : 'false'
      );
    });
    navMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navMenu.classList.remove('active');
        hamburger.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // ── Navbar scroll effect ─────────────────────────────
  // On applique le style DIRECTEMENT via JS (pas via classe CSS)
  // Raison : les media queries peuvent overrider la classe avec une spécificité plus haute
  const navbar = document.getElementById('navbar');

  function updateNavbar() {
    if (!navbar) return;
    if (window.scrollY > 40) {
      // Scrollé : glassmorphism fort
      navbar.style.background = 'rgba(13, 13, 24, 0.9)';
      navbar.style.backdropFilter = 'blur(20px)';
      navbar.style.webkitBackdropFilter = 'blur(20px)';
      navbar.style.borderBottomColor = 'rgba(139, 92, 246, 0.15)';
      navbar.style.boxShadow = '0 4px 32px rgba(0, 0, 0, 0.4)';
    } else {
      // En haut : transparent
      navbar.style.background = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.webkitBackdropFilter = 'none';
      navbar.style.borderBottomColor = 'transparent';
      navbar.style.boxShadow = 'none';
    }
  }

  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar(); // état initial

  // ── aria-current sur le lien actif ────────────────────
  function setActiveNavLink() {
    const hash = window.location.hash || '#hero';
    document.querySelectorAll('.nav-links a').forEach((link) => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#') && href === hash) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }
  setActiveNavLink();
  window.addEventListener('hashchange', setActiveNavLink);
</script>
