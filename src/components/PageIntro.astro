---
/**
 * PageIntro — Animation d'entrée (Intro Animation / Page Loader)
 *
 * 📚 LEÇON — Qu'est-ce qu'une intro animation ?
 * C'est un overlay (couche par-dessus) qui couvre tout le site au démarrage,
 * affiche quelque chose de beau, puis disparaît pour révéler le contenu.
 *
 * sessionStorage : mémoire temporaire du navigateur, effacée à la fermeture de l'onglet.
 * On l'utilise pour ne jouer l'animation qu'UNE seule fois par session.
 *   → Nouvelle session = animation jouée
 *   → Refresh = pas de re-animation (déjà vue)
 */
---

<div id="page-intro" aria-hidden="true">
  <div class="intro-content">
    <div class="intro-logo">
      <span class="intro-name">RachidRuffin</span><span class="intro-tld">.dev</span>
    </div>
    <div class="intro-line"></div>
  </div>
</div>

<style>
  #page-intro {
    position: fixed;
    inset: 0; /* top:0 right:0 bottom:0 left:0 en une ligne */
    z-index: 9999; /* Au-dessus de TOUT */
    background: #080810;
    display: flex;
    align-items: center;
    justify-content: center;
    /* État initial : visible */
    opacity: 1;
    transition: opacity 0.7s ease;
    /* Empêche le scroll pendant l'animation */
    pointer-events: all;
  }

  /* Quand JS ajoute la classe .done → l'overlay disparaît */
  #page-intro.done {
    opacity: 0;
    pointer-events: none; /* Plus cliquable une fois invisible */
  }

  .intro-content {
    text-align: center;
    animation: introFadeUp 0.7s ease both;
  }

  .intro-logo {
    font-size: clamp(2rem, 8vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .intro-name {
    background: linear-gradient(135deg, #e2e8f0, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .intro-tld {
    color: #22d3ee;
  }

  /* Ligne gradient qui apparaît sous le logo */
  .intro-line {
    height: 2px;
    background: linear-gradient(to right, transparent, #a78bfa, #22d3ee, transparent);
    animation: introLineGrow 0.6s 0.4s ease both;
    transform-origin: center;
  }

  @keyframes introFadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes introLineGrow {
    from {
      transform: scaleX(0);
      opacity: 0;
    }
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }
</style>

<script type="module" is:inline>
  const intro = document.getElementById('page-intro');
  if (!intro) return; // sécurité

  // Vérifier si l'intro a déjà été jouée cette session
  const alreadySeen = sessionStorage.getItem('intro-seen');

  if (alreadySeen) {
    // Déjà vue → on cache immédiatement sans animation
    intro.style.display = 'none';
  } else {
    // Première visite de la session → jouer l'intro
    // Marquer comme vue dans sessionStorage
    sessionStorage.setItem('intro-seen', '1');

    // Attendre que le CSS soit chargé, puis déclencher le fade-out
    // 1400ms = temps d'appréciation du logo (700ms animation + 700ms pause)
    setTimeout(() => {
      intro.classList.add('done');

      // Après la transition CSS (700ms), cacher complètement pour libérer le DOM
      setTimeout(() => {
        intro.style.display = 'none';
      }, 700);
    }, 1400);
  }
</script>
