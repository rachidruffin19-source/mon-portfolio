---

---

<div id="page-intro" aria-hidden="true">
  <div class="pi-glow"></div>
  <div class="pi-content">
    <div class="pi-logo">
      <span class="pi-name">RachidRuffin</span><span class="pi-tld">.dev</span>
    </div>
    <div class="pi-bar-wrap">
      <div class="pi-bar"></div>
    </div>
  </div>
</div>

<style>
  /* ── Overlay ──────────────────────────────────────────── */
  #page-intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #06060f;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    pointer-events: none; /* jamais bloquant */
    animation: pi-exit 0.8s 1.6s cubic-bezier(0.4, 0, 1, 1) forwards;
  }

  @keyframes pi-exit {
    0% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      visibility: hidden;
    }
  }

  /* ── Glow ambiant derrière le logo ────────────────────── */
  .pi-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
    animation: pi-glow-pulse 1.6s ease infinite alternate;
    pointer-events: none;
  }

  @keyframes pi-glow-pulse {
    from {
      transform: scale(0.85);
      opacity: 0.6;
    }
    to {
      transform: scale(1.1);
      opacity: 1;
    }
  }

  /* ── Contenu (logo + barre) ───────────────────────────── */
  .pi-content {
    position: relative;
    text-align: center;
    animation: pi-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes pi-rise {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Logo ─────────────────────────────────────────────── */
  .pi-logo {
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1.25rem;
  }

  .pi-name {
    background: linear-gradient(135deg, #ffffff 30%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pi-tld {
    background: linear-gradient(135deg, #a78bfa, #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Barre de progression stylisée ───────────────────── */
  .pi-bar-wrap {
    width: clamp(140px, 30vw, 280px);
    height: 2px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 2px;
    margin: 0 auto;
    overflow: hidden;
  }

  .pi-bar {
    height: 100%;
    width: 0%;
    border-radius: 2px;
    background: linear-gradient(to right, #a78bfa, #22d3ee);
    /* La barre se remplit en 1.4s = durée avant le fade-out */
    animation: pi-fill 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    box-shadow: 0 0 8px rgba(34, 211, 238, 0.5);
  }

  @keyframes pi-fill {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }
</style>

<script type="module" is:inline>
  const intro = document.getElementById('page-intro');
  if (!intro) return;

  if (sessionStorage.getItem('intro-seen')) {
    intro.style.display = 'none';
    return;
  }
  sessionStorage.setItem('intro-seen', '1');
  // Nettoyage DOM après fin de l'animation CSS (1.6s delay + 0.8s duration)
  setTimeout(() => intro.remove(), 2600);
</script>
